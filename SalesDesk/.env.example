# ══════════════════════════════════════════════════════════════════════════════
# SUPABASE
# Obtener en: https://supabase.com/dashboard/project/TU_PROYECTO/settings/api
# ══════════════════════════════════════════════════════════════════════════════

# URL del proyecto (Settings > API > Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://TU_PROYECTO.supabase.co

# Clave pública anónima — segura para exponer en el cliente
# (Settings > API > Project API Keys > anon public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key_aqui

# Clave de servicio — SOLO server-side, NUNCA incluir en el bundle del cliente
# (Settings > API > Project API Keys > service_role)
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_aqui

# ══════════════════════════════════════════════════════════════════════════════
# GENKIT / GOOGLE AI (opcional — para funciones de IA)
# Obtener en: https://aistudio.google.com/app/apikey
# ══════════════════════════════════════════════════════════════════════════════
GEMINI_API_KEY=
